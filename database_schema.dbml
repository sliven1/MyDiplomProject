// Database Schema для "Учеба рядом"
// Backend: PocketBase (SQLite)
// Визуализация: https://dbdiagram.io/
// ОБНОВЛЕНО: Все типы полей соответствуют нативным типам PocketBase

// ============================================
// ТЕКУЩИЕ КОЛЛЕКЦИИ (Реально существующие)
// ============================================

Table users {
  id text [pk, note: 'PocketBase Auth Collection ID (system)']
  email text [unique, note: 'EmailField (system field)']
  username text [unique, note: 'TextField (min:3, max:50)']
  name text [note: 'TextField - Полное имя (required, max:100)']
  birthDate date [note: 'DateField - Дата рождения']
  city text [note: 'TextField - Город проживания (max:100)']
  role text [note: 'SelectField - "student" | "tutor"']
  bio text [note: 'TextField - О себе (max:500)']
  avatar text [note: 'FileField - Имя файла (jpg/png/gif/webp, max:5MB, thumbs:100x100,300x300)']

  created date [note: 'AutodateField (system)']
  updated date [note: 'AutodateField (system)']

  Note: '''
  Auth Collection - встроенная авторизация PocketBase
  Пароль хеширован автоматически (bcrypt)
  allowEmailAuth: true, minPasswordLength: 8
  '''
}

Table messages {
  id text [pk]
  chatId text [note: 'RelationField → chats.id (связь с метаданными чата)']
  senderId text [note: 'RelationField → users.id']
  senderEmail text [note: 'TextField - Email отправителя (max:200)']
  receiverId text [note: 'RelationField → users.id']

  message text [note: 'TextField - Текст сообщения или URL файла (max:5000)']
  type text [note: 'SelectField - "text" | "image" | "audio"']
  isRead bool [default: false, note: 'BoolField - Прочитано или нет']

  created date [note: 'AutodateField - Время отправки']

  Indexes {
    chatId [name: 'idx_chatId']
    senderId [name: 'idx_senderId']
    receiverId [name: 'idx_receiverId']
  }

  Note: '''
  Базовая коллекция сообщений
  Связь с чатом через RelationField (chatId → chats.id)
  Файлы (изображения/аудио) пока хранятся как URL в поле message
  TODO: Мигрировать на FileField (imageFile, audioFile)
  '''
}

Table slots {
  id text [pk]
  tutorId text [note: 'RelationField → users.id']
  date date [note: 'DateField - Дата занятия (normalized to 00:00:00)']
  startTime text [note: 'TextField - "HH:MM" (pattern: ^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$)']
  endTime text [note: 'TextField - "HH:MM" (pattern: ^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$)']

  isBooked bool [default: false, note: 'BoolField - Забронирован слот']
  isPaid bool [default: false, note: 'BoolField - Оплачено занятие']

  studentId text [null, note: 'RelationField → users.id (optional)']

  generatedFromTemplate bool [default: false, note: 'BoolField - Создан ли из шаблона автоматически']
  templateId text [null, note: 'RelationField → weekly_templates.id (optional)']

  created date [note: 'AutodateField']
  updated date [note: 'AutodateField']

  Indexes {
    tutorId [name: 'idx_tutorId']
    date [name: 'idx_date']
  }

  Note: '''
  Временные слоты репетиторов
  startTime/endTime - TextField, т.к. только время без даты
  generatedFromTemplate - true если создан автоматически из weekly_templates
  '''
}

Table weekly_templates {
  id text [pk]
  tutorId text [note: 'RelationField → users.id']
  dayOfWeek number [note: 'NumberField - 1-7 (1=Пн, 7=Вс)']
  startTime text [note: 'TextField - "HH:MM" (pattern: ^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$)']
  endTime text [note: 'TextField - "HH:MM" (pattern: ^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$)']
  isActive bool [default: true, note: 'BoolField - Активен ли шаблон']

  created date [note: 'AutodateField']
  updated date [note: 'AutodateField']

  Indexes {
    tutorId [name: 'idx_tutorId']
    (tutorId, dayOfWeek) [name: 'idx_tutor_day']
  }

  Note: '''
  Недельный шаблон расписания репетитора

  Архитектура:
  - weekly_templates: абстрактный график ("каждый понедельник 10:00-12:00")
  - slots: конкретные слоты на конкретные даты ("15 марта 2026 10:00-12:00")

  Процесс:
  1. Репетитор настраивает weekly_templates через WeeklyTemplateSetupPage
  2. При нажатии "Применить" система генерирует slots на 28 дней вперёд
  3. Старые сгенерированные свободные слоты удаляются (забронированные остаются)
  4. Новые слоты создаются с полями generatedFromTemplate=true, templateId
  '''
}

Table blocked_users {
  id text [pk]
  userId text [note: 'RelationField → users.id (cascade delete)']
  blockedUserId text [note: 'RelationField → users.id (cascade delete)']

  created date [note: 'AutodateField']

  Indexes {
    (userId, blockedUserId) [unique, name: 'idx_user_blocked']
  }

  Note: 'Заблокированные пользователи'
}

Table reports {
  id text [pk]
  reportedBy text [note: 'RelationField → users.id']
  messageId text [note: 'RelationField → messages.id (cascade delete)']
  messageOwnerId text [note: 'RelationField → users.id']

  created date [note: 'AutodateField']

  Note: 'Жалобы на сообщения в чатах'
}

Table chats {
  id text [pk, note: 'PocketBase ID чата']
  user1Id text [note: 'RelationField → users.id (первый участник)']
  user2Id text [note: 'RelationField → users.id (второй участник)']

  lastMessage text [null, note: 'TextField - Текст последнего сообщения (макс 500)']
  lastMessageType text [note: 'SelectField - "text" | "image" | "audio"']
  lastSenderId text [note: 'RelationField → users.id']
  lastTimestamp date [note: 'DateField - Время последнего сообщения']

  unreadCountUser1 number [default: 0, note: 'NumberField - Непрочитанные для user1']
  unreadCountUser2 number [default: 0, note: 'NumberField - Непрочитанные для user2']

  created date [note: 'AutodateField']
  updated date [note: 'AutodateField']

  Indexes {
    (user1Id, user2Id) [unique, name: 'idx_users_pair']
  }

  Note: '''
  Метаданные чатов для быстрого списка (Two-Table Pattern)

  РЕШЕНИЕ: Две таблицы с жесткой связью через RelationField
  - chats: метаданные (список чатов на HomePage)
  - messages: все сообщения (история в ChatPage) с полем chatId → chats.id

  Преимущества:
  - Каскадное удаление (удалил чат → удалились все сообщения)
  - Referential integrity на уровне БД
  - Unique constraint на пару (user1Id, user2Id)

  Автообновляется через _createOrUpdateChatRoom() после каждой отправки
  '''
}

// ============================================
// ПЛАНИРУЕМЫЕ КОЛЛЕКЦИИ (Для диплома)
// ============================================

Table tutor_profiles {
  id text [pk]
  userId text [unique, note: 'RelationField → users.id']
  subjects json [note: 'JSONField - ["Математика", "Физика"]']
  priceMin number [note: 'NumberField - Минимальная цена за час']
  priceMax number [note: 'NumberField - Максимальная цена за час']
  experience number [note: 'NumberField - Опыт работы в годах']
  education text [note: 'TextField - Образование (вуз, специальность)']
  lessonFormat json [note: 'JSONField - ["online", "offline", "both"]']

  rating number [default: 0, note: 'NumberField - Средний взвешенный рейтинг (0-5)']
  totalPaidLessons number [default: 0, note: 'NumberField - Всего оплаченных занятий']
  lastPaidLessonDate date [null, note: 'DateField - Дата последнего оплаченного занятия']
  isNewbie bool [default: true, note: 'BoolField - Показывать бейдж 🆕']

  created date [note: 'AutodateField']
  updated date [note: 'AutodateField']

  Note: '⚠️ ПОКА НЕ СОЗДАНА - Расширенные данные репетиторов'
}

Table payments {
  id text [pk]
  studentId text [note: 'RelationField → users.id']
  tutorId text [note: 'RelationField → users.id']
  slotId text [note: 'RelationField → slots.id']
  amount number [note: 'NumberField - Сумма оплаты']
  status text [default: 'pending', note: 'SelectField - "pending" | "completed" | "failed"']

  created date [note: 'AutodateField']

  Note: '⚠️ ПОКА НЕ СОЗДАНА - Имитация оплаты для диплома'
}

Table reviews {
  id text [pk]
  tutorId text [note: 'RelationField → users.id']
  studentId text [note: 'RelationField → users.id']
  rating number [note: 'NumberField - 1-5 звёзд (только если isVerified)']
  comment text [null, note: 'TextField - Текстовый отзыв']
  isVerified bool [note: 'BoolField - true если оплаченное занятие']
  lessonId text [null, note: 'RelationField → slots.id']
  weight number [note: 'NumberField - Вес отзыва = кол-во занятий с этим учеником']

  created date [note: 'AutodateField']

  Note: '⚠️ ПОКА НЕ СОЗДАНА - Система отзывов'
}

// ============================================
// СВЯЗИ (REFERENCES)
// ============================================

// Слоты
Ref: slots.tutorId > users.id
Ref: slots.studentId > users.id
Ref: slots.templateId > weekly_templates.id

// Недельные шаблоны
Ref: weekly_templates.tutorId > users.id

// Сообщения
Ref: messages.chatId > chats.id [delete: cascade]
Ref: messages.senderId > users.id
Ref: messages.receiverId > users.id

// Блокировки
Ref: blocked_users.userId > users.id
Ref: blocked_users.blockedUserId > users.id

// Жалобы
Ref: reports.reportedBy > users.id
Ref: reports.messageId > messages.id
Ref: reports.messageOwnerId > users.id

// Чаты (метаданные)
Ref: chats.user1Id > users.id
Ref: chats.user2Id > users.id
Ref: chats.lastSenderId > users.id

// === ПЛАНИРУЕМЫЕ СВЯЗИ ===

// Профили репетиторов (когда создадим)
Ref: tutor_profiles.userId > users.id

// Платежи (когда создадим)
Ref: payments.studentId > users.id
Ref: payments.tutorId > users.id
Ref: payments.slotId > slots.id

// Отзывы (когда создадим)
Ref: reviews.tutorId > users.id
Ref: reviews.studentId > users.id
Ref: reviews.lessonId > slots.id

// ============================================
// СТАТУС МИГРАЦИИ
// ============================================

// ✅ ПОЛНОСТЬЮ МИГРИРОВАНО:
// - users (Auth Collection)
// - messages (текстовые + URL файлов)
// - chats (метаданные для списка чатов) - Two-Table Pattern ✅
// - slots (расписание) + weekly_templates (недельный шаблон) ✅
// - blocked_users (блокировки)
// - reports (жалобы)

// 🔄 В ПРОЦЕССЕ:
// - Файлы в чатах (изображения/аудио) используют Cloudinary
//   TODO: миграция на PocketBase Storage (добавить FileField: imageFile, audioFile)

// ⏳ ПЛАНИРУЕТСЯ ДЛЯ ДИПЛОМА:
// - tutor_profiles (расширенные данные репетиторов)
// - reviews (отзывы и рейтинги)
// - payments (имитация оплаты)

// ============================================
// ТИПЫ ПОЛЕЙ POCKETBASE (Официальные)
// ============================================
// TextField       - обычные строки (name, username, city, bio, message, education, chatRoomId, etc.)
// EmailField      - email адреса (system field в Auth Collection)
// URLField        - URL адреса
// NumberField     - числа (цены, рейтинги, счётчики) - поддерживает int и float
// BoolField       - булевы значения true/false (isRead, isBooked, isPaid, isVerified, isNewbie)
// DateField       - даты и время в RFC3339 (birthDate, date, lastTimestamp, lastPaidLessonDate)
// AutodateField   - автодаты для created/updated (system fields)
// SelectField     - enum значения (role, type, status, lastMessageType)
// JSONField       - JSON данные (subjects, lessonFormat) - единственный nullable тип
// FileField       - файлы (avatar, image, audio)
// RelationField   - связи между коллекциями (userId, tutorId, senderId, etc.)
// EditorField     - HTML-форматированный текст (не используется)
// GeoPointField   - географические координаты (не используется)

// ============================================
// КЛЮЧЕВЫЕ ИЗМЕНЕНИЯ
// ============================================
// ✅ text → date для всех дат (birthDate, created, updated, lastTimestamp, date, lastPaidLessonDate)
// ✅ text/integer → bool для всех булевых (isRead, isBooked, isPaid, isVerified, isNewbie)
// ✅ integer/real → number для всех чисел (цены, рейтинги, счётчики, веса)
// ✅ text → json для массивов (subjects, lessonFormat)
// ✅ Добавлены комментарии с типами PocketBase для каждого поля
// ✅ startTime/endTime остаются TextField, т.к. хранят только время без даты
// ✅ АРХИТЕКТУРА ЧАТОВ:
//    - messages.chatRoomId (TextField) → messages.chatId (RelationField → chats.id)
//    - chats.chatRoomId (TextField) → УБРАНО
//    - Добавлен unique index на (user1Id, user2Id) в chats
//    - Добавлена связь messages.chatId → chats.id с cascade delete
//    - Теперь удаление чата автоматически удаляет все его сообщения
